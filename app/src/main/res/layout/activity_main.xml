<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        >
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="10dp"
            >
            <android.widget.Button
                android:id="@+id/export_save_btn"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:layout_marginVertical="10dp"
                android:layout_marginHorizontal="5dp"
                android:padding="0dp"
                android:background="@drawable/button_background"
                android:text="@string/export_save_file"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                />
            <android.widget.Button
                android:id="@+id/import_save_btn"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:layout_marginVertical="10dp"
                android:layout_marginHorizontal="5dp"
                android:padding="0dp"
                android:background="@drawable/button_background"
                android:text="@string/import_save_file"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                />
        </LinearLayout>
        <WebView
            android:id="@+id/game_webview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="10dp"
            >
            <android.widget.Button
                android:id="@+id/delete_save_btn"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:layout_marginVertical="10dp"
                android:layout_marginHorizontal="5dp"
                android:padding="0dp"
                android:background="@drawable/button_background"
                android:text="@string/delete_save_file"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                />
            <android.widget.Button
                android:id="@+id/show_info_btn"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:layout_marginVertical="10dp"
                android:layout_marginHorizontal="5dp"
                android:padding="0dp"
                android:background="@drawable/button_background"
                android:text="@string/show_info_tip"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>